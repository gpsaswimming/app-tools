# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.fseventsd

# Claude Code
.claude/

# Python
__pycache__/
*.pyc

# Node.js
publicity-server/node_modules/
publicity-intake/node_modules/

# relay-builder local state (SQLite pool DB — never commit swimmer data)
relay-builder/.venv/
relay-builder/data/
*.db

# Secrets
publicity-intake/.env
publicity-intake/.env.dev

# Working directories
incoming/
preview/
temp/

# Raw meet-result files — real ones carry minors' birthdates/PII, never commit
*.sd3
*.hy3
*.zip
# Exception: swimparse golden-test fixtures are sanitized (fake public-figure data)
!swimparse/test/fixtures/*.sd3
!swimparse/test/fixtures/*.hy3

# Logs
*.log
