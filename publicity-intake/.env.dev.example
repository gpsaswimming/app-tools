# Copy to .env.dev and fill in. Never commit the real .env.dev.
# Used only by docker-compose.dev.yml to validate the GHCR :dev image.

# n8n webhook that receives the email + results file (multipart/form-data).
# For an n8n "Test URL" the path is /webhook-test/... and the workflow must be
# in "Listen for test event" mode; a live workflow uses /webhook/...
N8N_WEBHOOK_URL=https://your-n8n/webhook-test/gpsa-results-intake

# Optional shared-secret header (set BOTH to enable; must match n8n Header Auth).
# N8N_AUTH_HEADER=X-GPSA-Token
# N8N_AUTH_TOKEN=replace-with-a-long-random-secret
