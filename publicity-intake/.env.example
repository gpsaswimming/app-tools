# Copy to .env and fill in. Never commit the real .env.
# The n8n webhook that receives the email + results file (multipart/form-data).
N8N_WEBHOOK_URL=https://n8n.example.org/webhook/gpsa-results-intake

# Optional shared-secret header (n8n "Header Auth" credential). Set BOTH to
# require every forwarded request to carry the secret; n8n rejects anything
# without it. The header name + value must match the n8n webhook's Header Auth.
# N8N_AUTH_HEADER=X-GPSA-Token
# N8N_AUTH_TOKEN=replace-with-a-long-random-secret

# Optional overrides
# PORT=8080
# N8N_TIMEOUT_MS=15000
